# API Keys & External Services
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
LANGSMITH_API_KEY=your_langsmith_api_key_here

# JWT & Security
JWT_SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/auto_agentic

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# AI Models
MODEL_SIMPLE=llama-3.1-8b-instant
MODEL_COMPLEX=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Token Limits
MAX_TOKENS_SIMPLE=700
MAX_TOKENS_COMPLEX=1400

# CORS & Origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# LangSmith Tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=auto-agentic
